{
  "expo": {
    "name": "BazaarX",
    "slug": "bazaarx-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "bazaarx",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6A00"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bazaarx.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FF6A00"
      },
      "package": "com.bazaarx.mobile"
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BazaarX to access your camera to search products by image."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow BazaarX to access your photos to save and share media.",
          "savePhotosPermission": "Allow BazaarX to save photos and videos to your gallery.",
          "isAccessMediaLocationEnabled": false,
          "granularPermissions": [
            "photo",
            "video"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BazaarX to access your photos to attach images.",
          "cameraPermission": "Allow BazaarX to access your camera."
        }
      ],
      "expo-av",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ]
  }
}
