## Task 6: Rewrite `calculateShippingForSellers()` Main Loop

**File:** `src/services/shippingService.ts` (MODIFY)

### Replace the entire `calculateShippingForSellers()` function (lines 321-419)

```typescript
const INTERNATIONAL_FLAT_FEE = 70; // ₱ hardcoded for now

export async function calculateShippingForSellers(
  sellerInputs: SellerShippingInput[],
  buyerCoords: { latitude: number; longitude: number } | null,
  buyerProvince?: string | null,
  buyerRegion?: string | null,
): Promise<SellerShippingResult[]> {
  const config = await fetchShippingConfig();

  // Validate buyer location once
  const buyerStatus = validateLocation(buyerCoords, buyerProvince, buyerRegion);

  const results: SellerShippingResult[] = [];

  for (const input of sellerInputs) {
    try {
      // --- Guard 1: Validate seller location ---
      const sellerStatus = validateLocation(
        input.sellerCoords,
        input.sellerProvince,
        input.sellerRegion,
        input.sellerCountry,
      );

      // --- Guard 2: Seller has NO location at all ---
      if (sellerStatus.source === 'none') {
        results.push({
          sellerId: input.sellerId,
          sellerName: input.sellerName,
          originZone: 'Luzon',
          destinationZone: buyerStatus.zone ?? 'Luzon',
          chargeableWeight: 0,
          methods: [],
          defaultMethod: null,
          error: 'This seller has not set their store location. Shipping cannot be calculated.',
          distanceKm: null,
          sellerLocationStatus: sellerStatus,
          buyerLocationStatus: buyerStatus,
          isInternational: false,
        });
        continue;
      }

      // --- Guard 3: Buyer has NO location at all ---
      if (buyerStatus.source === 'none') {
        results.push({
          sellerId: input.sellerId,
          sellerName: input.sellerName,
          originZone: sellerStatus.zone ?? 'Luzon',
          destinationZone: 'Luzon',
          chargeableWeight: 0,
          methods: [],
          defaultMethod: null,
          error: 'Please add your delivery address with a valid location to calculate shipping.',
          distanceKm: null,
          sellerLocationStatus: sellerStatus,
          buyerLocationStatus: buyerStatus,
          isInternational: false,
        });
        continue;
      }

      // --- Guard 4: International seller bypass ---
      if (sellerStatus.isInternational) {
        const chargeableWeight = computeChargeableWeight(input.items, config.volumetric_divisor);
        const internationalMethod: ShippingMethodOption = {
          method: 'standard',
          label: 'International Shipping',
          fee: INTERNATIONAL_FLAT_FEE,
          breakdown: {
            baseRate: INTERNATIONAL_FLAT_FEE,
            weightSurcharge: 0,
            valuationFee: 0,
            odzFee: 0,
          },
          estimatedDays: '14–30 days',
          originZone: 'Luzon', // placeholder
          destinationZone: buyerStatus.zone ?? 'Luzon',
        };

        results.push({
          sellerId: input.sellerId,
          sellerName: input.sellerName,
          originZone: 'Luzon',
          destinationZone: buyerStatus.zone ?? 'Luzon',
          chargeableWeight,
          methods: [internationalMethod],
          defaultMethod: internationalMethod,
          error: null,
          distanceKm: null,
          sellerLocationStatus: sellerStatus,
          buyerLocationStatus: buyerStatus,
          isInternational: true,
        });
        continue;
      }

      // --- Normal flow: Both parties in PH ---
      const chargeableWeight = computeChargeableWeight(input.items, config.volumetric_divisor);
      const totalValue = computeTotalItemValue(input.items);

      // Calculate distance (prefer GPS, fallback to zone-based estimate)
      const geoResult = evaluateGeoDistance(buyerCoords, input.sellerCoords);
      const distanceKm = geoResult?.distanceKm ?? estimateDistanceFromZones(
        sellerStatus.zone, buyerStatus.zone
      );

      // Build method options using distance tiers
      const methods: ShippingMethodOption[] = [];
      const methodTypes: ShippingMethod[] = ['standard', 'economy', 'same_day', 'bulky'];

      for (const methodType of methodTypes) {
        // Same-day: only within 50km (local)
        if (methodType === 'same_day' && distanceKm > 50) continue;

        // Bulky: only when chargeable weight >= threshold
        if (methodType === 'bulky' && chargeableWeight < config.bulky_weight_threshold) continue;

        const tier = getDistanceTier(methodType, distanceKm);
        if (!tier) continue;

        methods.push(buildMethodFromDistance(
          methodType, tier, chargeableWeight, totalValue,
          config, distanceKm, sellerStatus.zone, buyerStatus.zone,
        ));
      }

      results.push({
        sellerId: input.sellerId,
        sellerName: input.sellerName,
        originZone: sellerStatus.zone ?? 'Luzon',
        destinationZone: buyerStatus.zone ?? 'Luzon',
        chargeableWeight,
        methods,
        defaultMethod: methods[0] ?? null,
        error: methods.length === 0 ? 'No shipping options available for this route.' : null,
        distanceKm,
        sellerLocationStatus: sellerStatus,
        buyerLocationStatus: buyerStatus,
        isInternational: false,
      });
    } catch (err: any) {
      console.error(`[shippingService] Error for seller ${input.sellerId}:`, err.message);
      results.push({
        sellerId: input.sellerId,
        sellerName: input.sellerName,
        originZone: 'Luzon',
        destinationZone: buyerStatus.zone ?? 'Luzon',
        chargeableWeight: 0,
        methods: [],
        defaultMethod: null,
        error: err.message ?? 'Shipping calculation failed.',
        distanceKm: null,
        sellerLocationStatus: validateLocation(null),
        buyerLocationStatus: buyerStatus,
        isInternational: false,
      });
    }
  }

  return results;
}

/**
 * Rough distance estimate when GPS coordinates are unavailable.
 * Falls back to zone-pair approximations.
 */
function estimateDistanceFromZones(
  originZone: ShippingZone | null,
  destZone: ShippingZone | null,
): number {
  if (!originZone || !destZone) return 300; // unknown → assume mid-range

  if (originZone === destZone) return 25; // same zone → local

  const ZONE_DISTANCES: Record<string, number> = {
    'NCR-Luzon': 100,
    'NCR-Visayas': 570,
    'NCR-Mindanao': 950,
    'Luzon-Visayas': 500,
    'Luzon-Mindanao': 850,
    'Visayas-Mindanao': 400,
  };

  const key1 = `${originZone}-${destZone}`;
  const key2 = `${destZone}-${originZone}`;
  return ZONE_DISTANCES[key1] ?? ZONE_DISTANCES[key2] ?? 300;
}
```

