## Task 4: New Fee Formula (Replace `buildMethodOption`)

**File:** `src/services/shippingService.ts` (MODIFY)

### Replace `buildMethodOption()` (lines 273-307)

```typescript
/**
 * Build a shipping method option using distance-based tiers.
 *
 * Formula:
 *   Wv = (L × W × H) / volumetric_divisor        (volumetric weight)
 *   Wc = ceil(max(actualWeight, Wv))               (chargeable weight)
 *   Sw = max(0, Wc - 1) × tier.perKgRate           (weight surcharge)
 *   Fv = totalItemValue × config.insurance_rate     (valuation fee)
 *   ODZ = tier.baseRate × (tier.odzMultiplier - 1)  (outer delivery zone surcharge)
 *   Fee = tier.baseRate + Sw + Fv + ODZ             (total)
 */
function buildMethodFromDistance(
  method: ShippingMethod,
  tier: DistanceTier,
  chargeableWeight: number,
  totalValue: number,
  config: ShippingConfigRow,
  distanceKm: number,
  originZone: ShippingZone | null,
  destinationZone: ShippingZone | null,
): ShippingMethodOption {
  const Sw = Math.max(0, chargeableWeight - 1) * tier.perKgRate;
  const Fv = totalValue * config.insurance_rate;
  const ODZ = tier.baseRate * (tier.odzMultiplier - 1);
  const fee = Math.round(tier.baseRate + Sw + Fv + ODZ);

  const daysMin = tier.estimatedDaysMin;
  const daysMax = tier.estimatedDaysMax;
  const estimatedDays = daysMin === 0 && daysMax === 0
    ? 'Today'
    : daysMin === daysMax
      ? `${daysMin} day${daysMin !== 1 ? 's' : ''}`
      : `${daysMin}–${daysMax} days`;

  return {
    method,
    label: METHOD_LABELS[method] ?? method,
    fee,
    breakdown: {
      baseRate: tier.baseRate,
      weightSurcharge: parseFloat(Sw.toFixed(2)),
      valuationFee: parseFloat(Fv.toFixed(2)),
      odzFee: parseFloat(ODZ.toFixed(2)),
    },
    estimatedDays,
    originZone: originZone ?? 'Luzon',
    destinationZone: destinationZone ?? 'Luzon',
  };
}
```

