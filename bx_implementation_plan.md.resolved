## Task 2: Haversine Distance Function

**File:** `src/services/shippingService.ts` (MODIFY)

### Add after `getZoneFromText()` (after line 111)

```typescript
// ---------------------------------------------------------------------------
// Haversine distance calculation (replaces hardcoded zone-pair lookup)
// ---------------------------------------------------------------------------

const EARTH_RADIUS_KM = 6371;

/**
 * Calculate the great-circle distance between two GPS coordinates.
 * Uses the Haversine formula — accurate for distances > 1km on Earth's surface.
 *
 * @returns distance in kilometers, rounded to 1 decimal
 */
export function haversineDistanceKm(
  lat1: number, lng1: number,
  lat2: number, lng2: number,
): number {
  const toRad = (deg: number) => (deg * Math.PI) / 180;

  const dLat = toRad(lat2 - lat1);
  const dLng = toRad(lng2 - lng1);

  const a =
    Math.sin(dLat / 2) ** 2 +
    Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLng / 2) ** 2;

  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));

  return Math.round(EARTH_RADIUS_KM * c * 10) / 10; // 1 decimal precision
}

/**
 * Check if GPS coordinates are within the Philippine bounding box.
 */
export function isWithinPhilippines(lat: number, lng: number): boolean {
  return (
    lat >= PH_BOUNDS.minLat && lat <= PH_BOUNDS.maxLat &&
    lng >= PH_BOUNDS.minLng && lng <= PH_BOUNDS.maxLng
  );
}

/**
 * Full geospatial evaluation between buyer and seller.
 * Returns distance, PH-membership for both parties, and international flag.
 */
export function evaluateGeoDistance(
  buyerCoords: { latitude: number; longitude: number } | null,
  sellerCoords: { latitude: number; longitude: number } | null,
): GeoDistanceResult | null {
  if (!buyerCoords || !sellerCoords) return null;

  const buyerInPH = isWithinPhilippines(buyerCoords.latitude, buyerCoords.longitude);
  const sellerInPH = isWithinPhilippines(sellerCoords.latitude, sellerCoords.longitude);

  return {
    distanceKm: haversineDistanceKm(
      buyerCoords.latitude, buyerCoords.longitude,
      sellerCoords.latitude, sellerCoords.longitude,
    ),
    buyerCoords,
    sellerCoords,
    isInternational: !buyerInPH || !sellerInPH,
    buyerInPH,
    sellerInPH,
  };
}
```

**Exit criteria:** `haversineDistanceKm(14.5995, 120.9842, 10.3157, 123.8854)` returns ~565 km (Manila→Cebu).

