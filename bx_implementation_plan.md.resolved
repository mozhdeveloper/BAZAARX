## Task 5: Null/Invalid Seller Location Guard

**File:** `src/services/shippingService.ts` (MODIFY)

### Add location validation helper

Add before `calculateShippingForSellers()`:

```typescript
/**
 * Validate location data for a single party.
 * Returns structured status used by both the calculation engine and the UI.
 */
function validateLocation(
  coords: { latitude: number; longitude: number } | null,
  province?: string | null,
  region?: string | null,
  country?: string | null,
): LocationValidationStatus {
  // Explicit international flag
  if (country && country.toLowerCase() !== 'ph' && country.toLowerCase() !== 'philippines') {
    return {
      hasCoords: !!coords,
      isInPH: false,
      isInternational: true,
      zone: null,
      source: 'none',
    };
  }

  // Has GPS coordinates
  if (coords && coords.latitude !== 0 && coords.longitude !== 0) {
    const inPH = isWithinPhilippines(coords.latitude, coords.longitude);
    if (inPH) {
      return {
        hasCoords: true,
        isInPH: true,
        isInternational: false,
        zone: getZoneFromCoords(coords.latitude, coords.longitude),
        source: 'gps',
      };
    } else {
      return {
        hasCoords: true,
        isInPH: false,
        isInternational: true,
        zone: null,
        source: 'gps',
      };
    }
  }

  // Text fallback — only if province/region exists
  if (province || region) {
    return {
      hasCoords: false,
      isInPH: true, // assumed PH if province/region text exists
      isInternational: false,
      zone: getZoneFromText(province ?? null, region ?? null),
      source: 'text',
    };
  }

  // No location data at all
  return {
    hasCoords: false,
    isInPH: false,
    isInternational: false,
    zone: null,
    source: 'none',
  };
}
```

