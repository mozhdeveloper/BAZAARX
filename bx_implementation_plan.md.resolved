## Task 3: Distance-Based Fee Tiers (Replace `shipping_zones` DB Lookup)

**File:** `src/services/shippingService.ts` (MODIFY)

### Replace `fetchShippingZones()` with distance tier logic

Remove or deprecate `fetchShippingZones()` (lines 174-189). Replace with:

```typescript
// ---------------------------------------------------------------------------
// Distance-based fee tiers (replaces shipping_zones DB table)
// ---------------------------------------------------------------------------

/**
 * Fee tiers based on Haversine distance between buyer and seller.
 * These are derived from J&T Express Philippines zone-pair rates
 * mapped to approximate distances.
 *
 * Tier structure:
 *   Local (0-50km)    → Same city / NCR-to-NCR
 *   Metro (50-150km)  → Same island, nearby provinces
 *   Regional (150-500km) → Same island, distant provinces
 *   Inter-island (500-1500km) → Cross-island (e.g., Luzon→Visayas)
 *   Remote (1500km+)  → Extreme routes (e.g., NCR→BARMM islands)
 */
const DISTANCE_TIERS: Record<ShippingMethod, DistanceTier[]> = {
  standard: [
    { minKm: 0,    maxKm: 50,   baseRate: 85,  perKgRate: 10, odzMultiplier: 1.0, estimatedDaysMin: 1, estimatedDaysMax: 2 },
    { minKm: 50,   maxKm: 150,  baseRate: 100, perKgRate: 12, odzMultiplier: 1.0, estimatedDaysMin: 2, estimatedDaysMax: 3 },
    { minKm: 150,  maxKm: 500,  baseRate: 130, perKgRate: 15, odzMultiplier: 1.1, estimatedDaysMin: 3, estimatedDaysMax: 5 },
    { minKm: 500,  maxKm: 1500, baseRate: 180, perKgRate: 20, odzMultiplier: 1.2, estimatedDaysMin: 5, estimatedDaysMax: 7 },
    { minKm: 1500, maxKm: 99999,baseRate: 250, perKgRate: 25, odzMultiplier: 1.5, estimatedDaysMin: 7, estimatedDaysMax: 14 },
  ],
  economy: [
    { minKm: 0,    maxKm: 50,   baseRate: 65,  perKgRate: 8,  odzMultiplier: 1.0, estimatedDaysMin: 3, estimatedDaysMax: 5 },
    { minKm: 50,   maxKm: 150,  baseRate: 75,  perKgRate: 10, odzMultiplier: 1.0, estimatedDaysMin: 5, estimatedDaysMax: 7 },
    { minKm: 150,  maxKm: 500,  baseRate: 95,  perKgRate: 12, odzMultiplier: 1.1, estimatedDaysMin: 7, estimatedDaysMax: 10 },
    { minKm: 500,  maxKm: 1500, baseRate: 130, perKgRate: 15, odzMultiplier: 1.2, estimatedDaysMin: 10, estimatedDaysMax: 14 },
    { minKm: 1500, maxKm: 99999,baseRate: 180, perKgRate: 20, odzMultiplier: 1.5, estimatedDaysMin: 14, estimatedDaysMax: 21 },
  ],
  same_day: [
    { minKm: 0,    maxKm: 50,   baseRate: 199, perKgRate: 20, odzMultiplier: 1.0, estimatedDaysMin: 0, estimatedDaysMax: 0 },
  ],
  bulky: [
    { minKm: 0,    maxKm: 50,   baseRate: 300, perKgRate: 8,  odzMultiplier: 1.0, estimatedDaysMin: 3, estimatedDaysMax: 5 },
    { minKm: 50,   maxKm: 500,  baseRate: 450, perKgRate: 10, odzMultiplier: 1.2, estimatedDaysMin: 5, estimatedDaysMax: 10 },
    { minKm: 500,  maxKm: 99999,baseRate: 650, perKgRate: 15, odzMultiplier: 1.5, estimatedDaysMin: 7, estimatedDaysMax: 14 },
  ],
};

/**
 * Resolve the fee tier for a given shipping method and distance.
 */
function getDistanceTier(method: ShippingMethod, distanceKm: number): DistanceTier | null {
  const tiers = DISTANCE_TIERS[method];
  if (!tiers) return null;
  return tiers.find(t => distanceKm >= t.minKm && distanceKm < t.maxKm) || tiers[tiers.length - 1];
}
```

**Exit criteria:** `getDistanceTier('standard', 300)` returns the 150-500km tier with baseRate 130.

