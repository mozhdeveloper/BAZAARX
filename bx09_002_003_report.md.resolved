### 1. [NEW] `src/types/shipping.types.ts`

**Purpose:** Shared TypeScript interfaces for method selection state and DB persistence.

**Contains 2 interfaces:**

#### `SelectedShippingMethod`
```typescript
{
  sellerId: string;          // which seller
  method: ShippingMethod;    // 'standard' | 'economy' | 'same_day' | 'bulky'
  label: string;             // 'J&T Standard'
  fee: number;               // ₱135
  breakdown: ShippingBreakdown; // { baseRate, weightSurcharge, valuationFee, odzFee }
  estimatedDays: string;     // '3-5 days'
  originZone: ShippingZone;  // 'NCR'
  destinationZone: ShippingZone; // 'Visayas'
}
```

#### `OrderShipmentInsert`
```typescript
{
  order_id: string;
  seller_id: string;
  shipping_method: ShippingMethod;
  shipping_method_label: string;
  calculated_fee: number;
  fee_breakdown: ShippingBreakdown;  // stored as JSONB in DB
  origin_zone: ShippingZone;
  destination_zone: ShippingZone;
  estimated_days_text: string;
  chargeable_weight_kg: number;
  tracking_number: string | null;    // null until seller ships
  status: 'pending' | 'shipped' | 'in_transit' | 'delivered';
}
